  <section class="mx-auto py-6 flex gap-2">
    <button class="button-change badge badge-sm badge-primary w-6"></button>
    <button class="button-change badge badge-sm"></button>
    <button class="button-change badge badge-sm"></button>
  </section>
</section>

<script is:inline>
  const containerSlider = document.getElementById('container-slider')
  const slider = containerSlider.getElementsByTagName('section')[0]
  const articles = slider.querySelectorAll('article')

  const sizeSlider = articles.length * 100
  const weightArticle = (1 / articles.length) * 100

  const translate = (1 / articles.length) * 100 * 2

  slider.style.width = `${sizeSlider}%`
  articles.forEach((article) => {
    article.style.width = `${weightArticle}%`
  })

  slider.style.transform = `translateX(-${translate}%)`
</script>
